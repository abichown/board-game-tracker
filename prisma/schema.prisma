// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GameRelationship {
  OWNED
  PLAYED_ELSEWHERE
  WISHLIST
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  userGames UserGame[]
  sessions  Session[]
}

model UserGame {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])

  boardGameId   Int
  boardGame     BoardGame     @relation(fields: [boardGameId], references: [id])

  relationship  GameRelationship
  source        String?
  acquiredAt    DateTime?

  createdAt     DateTime      @default(now())

  sessions      Session[]

  @@unique([userId, boardGameId])
}

model Session {
  id           String      @id @default(uuid())
  userId       String
  userGameId   String

  date         DateTime    @default(now())

  user         User        @relation(fields: [userId], references: [id])
  userGame     UserGame    @relation(fields: [userGameId], references: [id])

  players      SessionPlayer[]
}

model SessionPlayer {
  id        String   @id @default(uuid())
  sessionId String
  name      String
  isWinner  Boolean  @default(false)
  session   Session  @relation(fields: [sessionId], references: [id])
}

model BoardGame {
  id            Int          @id
  name          String
  yearPublished Int?
  rank          Int?
  bayesAverage  Float?
  average       Float?
  usersRated    Int?
  isExpansion   Boolean?

  userGames     UserGame[]
}